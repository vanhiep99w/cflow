#!/usr/bin/env bash
# cflow - Generate cflow skills into a project's .claude/ directory
# Usage: cflow init | update | remove | list | status

set -euo pipefail

VERSION="0.1.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Determine source: either local repo or downloaded
find_source_dir() {
  # If script is in the cflow repo, use that
  local repo_root
  repo_root="$(cd "$SCRIPT_DIR/.." && pwd)"
  if [ -d "$repo_root/skills" ] && [ -f "$repo_root/.claude-plugin/plugin.json" ]; then
    echo "$repo_root"
    return 0
  fi

  # Check for cached download
  local cache_dir="${HOME}/.cache/cflow"
  if [ -d "$cache_dir/skills" ]; then
    echo "$cache_dir"
    return 0
  fi

  echo ""
  return 1
}

# Download latest cflow source from GitHub
download_source() {
  local cache_dir="${HOME}/.cache/cflow"
  local repo="vanhiep99w/cflow"
  local branch="main"

  echo -e "${BLUE}Downloading cflow from GitHub...${NC}"
  mkdir -p "$cache_dir"

  if command -v git &>/dev/null; then
    if [ -d "$cache_dir/.git" ]; then
      (cd "$cache_dir" && git pull --quiet origin "$branch")
    else
      git clone --quiet --depth 1 "https://github.com/${repo}.git" "$cache_dir"
    fi
  elif command -v curl &>/dev/null; then
    local tmpfile
    tmpfile=$(mktemp)
    curl -fsSL "https://github.com/${repo}/archive/refs/heads/${branch}.tar.gz" -o "$tmpfile"
    rm -rf "$cache_dir"
    mkdir -p "$cache_dir"
    tar xzf "$tmpfile" -C "$cache_dir" --strip-components=1
    rm -f "$tmpfile"
  else
    echo -e "${RED}Error: git or curl required${NC}" >&2
    exit 1
  fi

  echo "$cache_dir"
}

# Get target project directory
get_target_dir() {
  pwd
}

# Generate a single command file from a skill
generate_command() {
  local skill_dir="$1"   # Full path to skill source directory
  local skill_name="$2"  # Skill name (e.g., "brainstorm")
  local target_dir="$3"  # Target project root
  local cf_data_dir="$4" # Supporting files destination

  local skill_md="${skill_dir}/SKILL.md"
  if [ ! -f "$skill_md" ]; then
    return
  fi

  # Extract frontmatter
  local description=""
  local in_frontmatter=0
  local frontmatter_done=0
  local body=""

  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$frontmatter_done" -eq 0 ]; then
      if [ "$line" = "---" ]; then
        if [ "$in_frontmatter" -eq 0 ]; then
          in_frontmatter=1
          continue
        else
          frontmatter_done=1
          continue
        fi
      fi
      if [ "$in_frontmatter" -eq 1 ]; then
        case "$line" in
          description:*)
            description="${line#description:}"
            description="${description# }"
            description="${description#\"}"
            description="${description%\"}"
            ;;
        esac
        continue
      fi
    fi
    body="${body}${line}
"
  done < "$skill_md"

  # Create command file
  local cmd_dir="${target_dir}/.claude/commands/cf"
  mkdir -p "$cmd_dir"

  local cmd_file="${cmd_dir}/${skill_name}.md"

  # Build the command file with frontmatter
  {
    echo "---"
    echo "description: \"${description}\""
    echo "---"
    echo ""
    # Transform cf: references to cf: (keep as-is for commands subdirectory format)
    # Transform relative file references to .claude/cf-data paths
    echo "$body" | transform_content "$skill_name" "$target_dir"
  } > "$cmd_file"

  # Copy supporting files
  local has_supporting=0
  local skill_dir_clean="${skill_dir%/}"
  while IFS= read -r -d '' file; do
    local rel_path="${file#"${skill_dir_clean}/"}"
    if [ "$rel_path" = "SKILL.md" ]; then
      continue
    fi
    # Skip node_modules and package-lock.json
    case "$rel_path" in
      node_modules/*|*/node_modules/*|package-lock.json) continue ;;
      scripts/node_modules/*) continue ;;
    esac

    has_supporting=1
    local dest="${cf_data_dir}/${skill_name}/${rel_path}"
    mkdir -p "$(dirname "$dest")"
    cp "$file" "$dest"
  done < <(find "$skill_dir_clean" -type f -not -path '*/node_modules/*' -not -name 'package-lock.json' -print0 2>/dev/null)

  if [ "$has_supporting" -eq 1 ]; then
    echo -e "  ${GREEN}+${NC} cf:${skill_name} (+ supporting files)"
  else
    echo -e "  ${GREEN}+${NC} cf:${skill_name}"
  fi
}

# Transform skill content for command file context
transform_content() {
  local skill_name="$1"
  local target_dir="$2"
  local cf_path=".claude/cf-data/${skill_name}"

  # Transform file references:
  # 1. ./file.ext → .claude/cf-data/<skill>/file.ext
  # 2. @file.ext → .claude/cf-data/<skill>/file.ext
  # 3. skills/<skill>/file → .claude/cf-data/<skill>/file
  # 4. review/code-reviewer.md → .claude/cf-data/review/code-reviewer.md
  # 5. skills/brainstorm/ → .claude/cf-data/brainstorm/
  sed \
    -e "s|\./\([a-zA-Z0-9_-]*\.md\)|${cf_path}/\1|g" \
    -e "s|\./\([a-zA-Z0-9_-]*\.ts\)|${cf_path}/\1|g" \
    -e "s|\./\([a-zA-Z0-9_-]*\.sh\)|${cf_path}/\1|g" \
    -e "s|\./\([a-zA-Z0-9_-]*\.js\)|${cf_path}/\1|g" \
    -e "s|\./\([a-zA-Z0-9_-]*\.dot\)|${cf_path}/\1|g" \
    -e "s|\./\([a-zA-Z0-9_-]*\.html\)|${cf_path}/\1|g" \
    -e "s|@\([a-zA-Z0-9_-]*\.md\)|${cf_path}/\1|g" \
    -e "s|@\([a-zA-Z0-9_-]*\.dot\)|${cf_path}/\1|g" \
    -e "s|@\([a-zA-Z0-9_-]*\.js\)|${cf_path}/\1|g" \
    -e "s|skills/${skill_name}/\([a-zA-Z0-9_/.-]*\)|${cf_path}/\1|g" \
    -e "s|skills/brainstorm/|.claude/cf-data/brainstorm/|g" \
    -e "s|review/code-reviewer\.md|.claude/cf-data/review/code-reviewer.md|g"
}

# Generate CLAUDE.md snippet
generate_claude_md() {
  local target_dir="$1"
  local claude_md="${target_dir}/CLAUDE.md"

  local snippet='<!-- cflow-start -->
## Cflow Workflow Skills

This project uses cflow agentic workflow skills. Skills are invoked as `/cf:<name>`.

**On session start:** Run `/cf:start` to initialize Beads task state and discover available workflow skills.

**Available skills:**
| Skill | When to invoke |
|-------|---------------|
| cf:brainstorm | Before any creative work — features, components, functionality |
| cf:design | After brainstorm, when project has UI components |
| cf:plan | After brainstorm, to create implementation plan |
| cf:implement | When you have a plan with tasks to execute |
| cf:sdd | When executing plans with subagents |
| cf:tdd | When implementing any feature or bugfix |
| cf:debug | When encountering bugs, test failures |
| cf:review | After completing tasks, before merging |
| cf:receive-review | When receiving code review feedback |
| cf:dispatch | For 2+ independent parallel tasks |
| cf:worktree | When starting feature work needing isolation |
| cf:verify | Before claiming work is complete |
| cf:finish | When implementation complete, ready to merge/PR |
| cf:pause | When user wants to stop and save context |
| cf:resume | When user wants to continue a paused task |
| cf:bug | When user reports a bug |
| cf:status | When user asks about progress |
| cf:write-skill | When creating or editing skills |

**Requirements:** Beads CLI (`bd`) must be installed. Pencil MCP optional for UI design.
<!-- cflow-end -->'

  if [ -f "$claude_md" ]; then
    # Check if cflow block already exists
    if grep -q '<!-- cflow-start -->' "$claude_md"; then
      # Replace existing block
      local tmpfile
      tmpfile=$(mktemp)
      awk '
        /<!-- cflow-start -->/ { skip=1; next }
        /<!-- cflow-end -->/ { skip=0; next }
        !skip { print }
      ' "$claude_md" > "$tmpfile"
      echo "" >> "$tmpfile"
      echo "$snippet" >> "$tmpfile"
      mv "$tmpfile" "$claude_md"
      echo -e "  ${GREEN}~${NC} Updated CLAUDE.md"
    else
      # Append to existing
      echo "" >> "$claude_md"
      echo "$snippet" >> "$claude_md"
      echo -e "  ${GREEN}+${NC} Appended to CLAUDE.md"
    fi
  else
    echo "$snippet" > "$claude_md"
    echo -e "  ${GREEN}+${NC} Created CLAUDE.md"
  fi
}

# Write version file
write_version() {
  local target_dir="$1"
  local source_dir="$2"
  local version_file="${target_dir}/.claude/.cf-version"

  local commit="unknown"
  if [ -d "$source_dir/.git" ]; then
    commit=$(cd "$source_dir" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  fi

  mkdir -p "$(dirname "$version_file")"
  cat > "$version_file" <<EOF
{
  "version": "${VERSION}",
  "commit": "${commit}",
  "installed": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "source": "https://github.com/vanhiep99w/cflow"
}
EOF
}

# Copy agent definitions
generate_agents() {
  local source_dir="$1"
  local target_dir="$2"
  local agents_src="${source_dir}/agents"

  if [ ! -d "$agents_src" ]; then
    return
  fi

  local agents_dst="${target_dir}/.claude/agents"
  mkdir -p "$agents_dst"

  for agent_file in "$agents_src"/*.md; do
    [ -f "$agent_file" ] || continue
    local basename
    basename=$(basename "$agent_file")
    cp "$agent_file" "${agents_dst}/${basename}"
    echo -e "  ${GREEN}+${NC} agent: ${basename}"
  done
}

# ---- Commands ----

cmd_init() {
  local target_dir
  target_dir=$(get_target_dir)

  echo -e "${BLUE}cflow init${NC} v${VERSION}"
  echo ""

  # Check for existing installation
  if [ -f "${target_dir}/.claude/.cf-version" ]; then
    echo -e "${YELLOW}Warning: cflow already installed in this project.${NC}"
    echo "Use 'cflow update' to update, or 'cflow remove' first to reinstall."
    echo ""
    read -rp "Continue anyway? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[yY] ]]; then
      echo "Aborted."
      exit 0
    fi
  fi

  # Find or download source
  local source_dir
  source_dir=$(find_source_dir) || source_dir=$(download_source)

  if [ -z "$source_dir" ] || [ ! -d "$source_dir/skills" ]; then
    echo -e "${RED}Error: Could not find cflow source${NC}" >&2
    exit 1
  fi

  echo "Source: ${source_dir}"
  echo "Target: ${target_dir}"
  echo ""

  # Create directories
  mkdir -p "${target_dir}/.claude/commands/cf"
  mkdir -p "${target_dir}/.claude/cf-data"

  local cf_data_dir="${target_dir}/.claude/cf-data"

  echo "Generating skills..."

  # Generate command files for each skill
  for skill_dir in "$source_dir"/skills/*/; do
    [ -d "$skill_dir" ] || continue
    local skill_name
    skill_name=$(basename "$skill_dir")
    generate_command "$skill_dir" "$skill_name" "$target_dir" "$cf_data_dir"
  done

  echo ""
  echo "Generating agents..."
  generate_agents "$source_dir" "$target_dir"

  echo ""
  echo "Configuring project..."
  generate_claude_md "$target_dir"
  write_version "$target_dir" "$source_dir"

  echo ""
  echo -e "${GREEN}Done!${NC} cflow skills installed."
  echo ""
  echo "Skills are available as /cf:<name> commands."
  echo "Start with: /cf:start"
}

cmd_update() {
  local target_dir
  target_dir=$(get_target_dir)

  if [ ! -f "${target_dir}/.claude/.cf-version" ]; then
    echo -e "${RED}Error: cflow not installed in this project.${NC}"
    echo "Run 'cflow init' first."
    exit 1
  fi

  echo -e "${BLUE}cflow update${NC}"
  echo ""

  # Get installed version info
  local installed_version installed_commit
  installed_version=$(grep '"version"' "${target_dir}/.claude/.cf-version" | sed 's/.*: *"\(.*\)".*/\1/')
  installed_commit=$(grep '"commit"' "${target_dir}/.claude/.cf-version" | sed 's/.*: *"\(.*\)".*/\1/')

  echo "Installed: v${installed_version} (${installed_commit})"

  # Download/update source
  local source_dir
  source_dir=$(find_source_dir) || source_dir=$(download_source)

  local current_commit="unknown"
  if [ -d "$source_dir/.git" ]; then
    current_commit=$(cd "$source_dir" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  fi

  echo "Available: v${VERSION} (${current_commit})"

  if [ "$installed_commit" = "$current_commit" ] && [ "$installed_version" = "$VERSION" ]; then
    echo ""
    echo -e "${GREEN}Already up to date.${NC}"
    exit 0
  fi

  echo ""
  echo "Updating skills..."

  # Remove old generated files
  rm -rf "${target_dir}/.claude/commands/cf"
  rm -rf "${target_dir}/.claude/cf-data"
  rm -rf "${target_dir}/.claude/agents"

  # Regenerate
  mkdir -p "${target_dir}/.claude/commands/cf"
  mkdir -p "${target_dir}/.claude/cf-data"

  local cf_data_dir="${target_dir}/.claude/cf-data"

  for skill_dir in "$source_dir"/skills/*/; do
    [ -d "$skill_dir" ] || continue
    local skill_name
    skill_name=$(basename "$skill_dir")
    generate_command "$skill_dir" "$skill_name" "$target_dir" "$cf_data_dir"
  done

  echo ""
  generate_agents "$source_dir" "$target_dir"
  generate_claude_md "$target_dir"
  write_version "$target_dir" "$source_dir"

  echo ""
  echo -e "${GREEN}Updated!${NC} v${installed_version} → v${VERSION}"
}

cmd_remove() {
  local target_dir
  target_dir=$(get_target_dir)

  if [ ! -f "${target_dir}/.claude/.cf-version" ]; then
    echo -e "${YELLOW}cflow not installed in this project.${NC}"
    exit 0
  fi

  echo -e "${BLUE}cflow remove${NC}"
  echo ""

  read -rp "Remove all cflow skills from this project? [y/N] " confirm
  if [[ ! "$confirm" =~ ^[yY] ]]; then
    echo "Aborted."
    exit 0
  fi

  # Remove generated files
  rm -rf "${target_dir}/.claude/commands/cf"
  rmdir "${target_dir}/.claude/commands" 2>/dev/null || true
  rm -rf "${target_dir}/.claude/cf-data"
  rm -f "${target_dir}/.claude/.cf-version"

  # Remove agents
  if [ -d "${target_dir}/.claude/agents" ]; then
    rm -f "${target_dir}/.claude/agents/code-reviewer.md"
    rmdir "${target_dir}/.claude/agents" 2>/dev/null || true
  fi

  # Clean up empty .claude directory
  rmdir "${target_dir}/.claude" 2>/dev/null || true

  # Remove CLAUDE.md block
  if [ -f "${target_dir}/CLAUDE.md" ]; then
    if grep -q '<!-- cflow-start -->' "${target_dir}/CLAUDE.md"; then
      local tmpfile
      tmpfile=$(mktemp)
      awk '
        /<!-- cflow-start -->/ { skip=1; next }
        /<!-- cflow-end -->/ { skip=0; next }
        !skip { print }
      ' "${target_dir}/CLAUDE.md" > "$tmpfile"
      # Remove trailing blank lines
      sed -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$tmpfile" > "${target_dir}/CLAUDE.md"
      rm -f "$tmpfile"
      # If CLAUDE.md is now empty, remove it
      if [ ! -s "${target_dir}/CLAUDE.md" ]; then
        rm -f "${target_dir}/CLAUDE.md"
      fi
    fi
  fi

  echo -e "${GREEN}Removed.${NC} All cflow skills have been uninstalled."
}

cmd_list() {
  local target_dir
  target_dir=$(get_target_dir)

  if [ ! -d "${target_dir}/.claude/commands/cf" ]; then
    echo -e "${YELLOW}cflow not installed in this project.${NC}"
    echo "Run 'cflow init' to install."
    exit 0
  fi

  echo -e "${BLUE}Installed cflow skills:${NC}"
  echo ""

  for cmd_file in "${target_dir}/.claude/commands/cf"/*.md; do
    [ -f "$cmd_file" ] || continue
    local name
    name=$(basename "$cmd_file" .md)
    local desc=""
    desc=$(grep '^description:' "$cmd_file" | head -1 | sed 's/^description: *//; s/^"//; s/"$//')
    local has_data=""
    if [ -d "${target_dir}/.claude/cf-data/${name}" ]; then
      has_data=" [+data]"
    fi
    echo -e "  ${GREEN}/cf:${name}${NC}${has_data}"
    if [ -n "$desc" ]; then
      echo "    ${desc}"
    fi
  done
}

cmd_status() {
  local target_dir
  target_dir=$(get_target_dir)

  if [ ! -f "${target_dir}/.claude/.cf-version" ]; then
    echo -e "${YELLOW}cflow not installed.${NC}"
    exit 0
  fi

  local installed_version installed_commit installed_date
  installed_version=$(grep '"version"' "${target_dir}/.claude/.cf-version" | sed 's/.*: *"\(.*\)".*/\1/')
  installed_commit=$(grep '"commit"' "${target_dir}/.claude/.cf-version" | sed 's/.*: *"\(.*\)".*/\1/')
  installed_date=$(grep '"installed"' "${target_dir}/.claude/.cf-version" | sed 's/.*: *"\(.*\)".*/\1/')

  local skill_count=0
  for f in "${target_dir}/.claude/commands/cf"/*.md; do
    [ -f "$f" ] && skill_count=$((skill_count + 1))
  done

  echo -e "${BLUE}cflow status${NC}"
  echo ""
  echo "  Version:   v${installed_version} (${installed_commit})"
  echo "  Installed: ${installed_date}"
  echo "  Skills:    ${skill_count}"
  echo "  Location:  ${target_dir}/.claude/commands/cf/"
}

cmd_help() {
  echo "cflow v${VERSION} - Agentic workflow skills for Claude Code"
  echo ""
  echo "Usage: cflow <command>"
  echo ""
  echo "Commands:"
  echo "  init     Install cflow skills into current project"
  echo "  update   Update skills to latest version"
  echo "  remove   Remove all cflow skills from project"
  echo "  list     List installed skills"
  echo "  status   Show installation info"
  echo "  help     Show this help"
  echo ""
  echo "Examples:"
  echo "  cd my-project && cflow init"
  echo "  cflow update"
  echo "  cflow list"
}

# ---- Main ----

case "${1:-help}" in
  init)    cmd_init ;;
  update)  cmd_update ;;
  remove)  cmd_remove ;;
  list)    cmd_list ;;
  status)  cmd_status ;;
  help|-h|--help) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    echo ""
    cmd_help
    exit 1
    ;;
esac
